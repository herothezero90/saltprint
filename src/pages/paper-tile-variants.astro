---
import '../styles/style.css';
---

<!doctype html>
<html lang="en" class="bg-ink">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Paper tile variants — Saltprint</title>
  </head>
  <body class="dark-paper-texture min-h-svh font-body text-paper">
    <main class="mx-auto w-full max-w-screen-2xl px-4 py-10 sm:px-8 lg:px-16 lg:py-16">
      <header class="mx-auto max-w-5xl text-center">
        <h1 class="text-3xl uppercase sm:text-5xl">Paper tile comparison</h1>
        <p class="mt-4 text-sm text-paper/80 sm:text-base">
          The original lettering and worn marks are preserved in both options.
        </p>
      </header>

      <div class="mt-12 grid gap-14 xl:grid-cols-2 xl:gap-10">
        <section aria-labelledby="solid-variant-title">
          <h2 id="solid-variant-title" class="text-2xl uppercase sm:text-3xl">
            A — sampled colours
          </h2>
          <p class="mt-2 text-sm text-paper/75">#d1c7a4 → #d0c6a2</p>

          <div
            class="paper-title-surface paper-title-surface-solid mt-6 rotate-1 shadow-2xl"
          >
            <img
              class="paper-title-art h-auto w-full"
              src="/images/section_names_img/how-to-submit.png"
              alt="How to Submit — sampled colour variant"
              width="2138"
              height="250"
            />
          </div>

          <div
            class="paper-title-surface paper-title-surface-solid mt-10 -rotate-1 shadow-2xl"
          >
            <img
              class="paper-title-art h-auto w-full"
              src="/images/saltprint-footer-reversed.png"
              alt="Saltprint — sampled colour variant"
              width="2124"
              height="353"
            />
          </div>
        </section>

        <section aria-labelledby="texture-variant-title">
          <h2 id="texture-variant-title" class="text-2xl uppercase sm:text-3xl">
            B — actual About paper
          </h2>
          <p class="mt-2 text-sm text-paper/75">
            A fold-free crop from the original background texture
          </p>

          <div
            class="paper-title-surface paper-title-surface-texture mt-6 rotate-1 shadow-2xl"
          >
            <img
              class="paper-title-art h-auto w-full"
              src="/images/section_names_img/how-to-submit.png"
              alt="How to Submit — actual paper texture variant"
              width="2138"
              height="250"
            />
          </div>

          <div
            class="paper-title-surface paper-title-surface-texture mt-10 -rotate-1 shadow-2xl [--paper-crop-y:8%]"
          >
            <img
              class="paper-title-art h-auto w-full"
              src="/images/saltprint-footer-reversed.png"
              alt="Saltprint — actual paper texture variant"
              width="2124"
              height="353"
            />
          </div>
        </section>
      </div>
    </main>
  </body>
</html>
