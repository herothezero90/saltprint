---
import HeroSection from '../components/sections/HeroSection.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import NewsletterSection from '../components/sections/NewsletterSection.astro';
import VolumeSection from '../components/sections/VolumeSection.astro';
import SubmissionsSection from '../components/sections/SubmissionsSection.astro';
import HowToSubmitSection from '../components/sections/HowToSubmitSection.astro';
import FaqSection from '../components/sections/FaqSection.astro';
import FooterSection from '../components/sections/FooterSection.astro';
import {getSiteContent} from '../content/sanityContent';
import '../styles/style.css';

const content = await getSiteContent();
const submissionFormAvailable =
  content.howToSubmit.statusCard.visible &&
  Boolean(content.howToSubmit.statusCard.formUrl.trim());
const pageTitle = 'Saltprint Zine';
const pageDescription =
  'Saltprint is an independent photography zine and print archive built through open calls for photographs taken across Europe.';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalUrl = new URL(`${base}/`, Astro.site ?? Astro.url);
const socialImage = new URL(`${base}/saltprint0logo.png`, Astro.site ?? Astro.url);
const websiteId = `${canonicalUrl}#website`;
const publisherId = `${canonicalUrl}#publisher`;
const periodicalId = `${canonicalUrl}#periodical`;
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': websiteId,
      url: canonicalUrl.toString(),
      name: 'Saltprint',
      description: pageDescription,
      inLanguage: 'en',
      publisher: {'@id': publisherId},
    },
    {
      '@type': 'Organization',
      '@id': publisherId,
      name: 'Saltprint',
      url: canonicalUrl.toString(),
      logo: {
        '@type': 'ImageObject',
        url: socialImage.toString(),
        width: 257,
        height: 246,
      },
      founder: {
        '@type': 'Person',
        name: 'Petra Zegnal',
      },
      sameAs: ['https://www.instagram.com/saltprint_zine/'],
    },
    {
      '@type': 'Periodical',
      '@id': periodicalId,
      name: 'Saltprint',
      url: canonicalUrl.toString(),
      description: pageDescription,
      inLanguage: 'en',
      publisher: {'@id': publisherId},
    },
  ],
};
---

<!doctype html>
<html lang="en" class="bg-map-base">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={`${base}/saltprint0logo.png`} />
    <link rel="apple-touch-icon" href={`${base}/saltprint0logo.png`} />
    <link rel="canonical" href={canonicalUrl} />
    <link
      rel="preload"
      href={`${base}/fonts/special-elite-latin-400-normal.woff2`}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href={`${base}/images/hero-map-mobile.webp`}
      as="image"
      type="image/webp"
      fetchpriority="high"
      media="(max-width: 63.999rem)"
    />
    <link
      rel="preload"
      href={`${base}/images/hero-map.webp`}
      as="image"
      type="image/webp"
      fetchpriority="high"
      media="(min-width: 64rem)"
    />
    <link
      rel="preload"
      href={`${base}/images/hero-logo-mobile.webp`}
      as="image"
      type="image/webp"
      fetchpriority="high"
      imagesrcset={`${base}/images/hero-logo-mobile.webp 800w, ${base}/images/hero-logo.webp 1600w`}
      imagesizes="(min-width: 64rem) 48vw, calc(100vw - 2rem)"
    />
    <link
      rel="preload"
      href={`${base}/images/hero-paper.webp`}
      as="image"
      type="image/webp"
      fetchpriority="high"
      imagesrcset={`${base}/images/hero-paper-800.webp 800w, ${base}/images/hero-paper.webp 1400w`}
      imagesizes="(min-width: 36rem) 36rem, calc(100vw - 2rem)"
    />
    <meta name="description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Saltprint" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="257" />
    <meta property="og:image:height" content="246" />
    <meta property="og:image:alt" content="Saltprint logo" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content="Saltprint logo" />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
    <script
      is:inline
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="eba4241a-cda4-4adb-97ec-228a3418e205"
    ></script>
    <title>{pageTitle}</title>
  </head>
  <body class="font-body text-ink">
    <a
      class="fixed top-2 left-2 z-100 -translate-y-20 rounded-sm bg-paper px-4 py-3 font-heading text-ink uppercase shadow-lg transition-transform focus:translate-y-0 focus:outline-2 focus:outline-offset-2 focus:outline-ink motion-reduce:transition-none"
      href="#about"
    >
      Skip to content
    </a>
    <main>
      <HeroSection
        openCall={content.hero}
        announcementHref={submissionFormAvailable ? '#how-to-submit' : undefined}
      />
      <AboutSection />
      <NewsletterSection />
      <VolumeSection
        volume={content.currentVolume}
        showArchiveLink
      />
      <SubmissionsSection content={content.submissions} />
      <HowToSubmitSection content={content.howToSubmit} />
      <FaqSection faqs={content.faqs} />
    </main>
    <FooterSection />
    <script src="../scripts/motion/sectionTitles.ts"></script>
  </body>
</html>
