---
import FooterSection from '../components/sections/FooterSection.astro';
import VolumeSection from '../components/sections/VolumeSection.astro';
import {getSiteContent} from '../content/sanityContent';
import '../styles/style.css';

const content = await getSiteContent();
const {archive, archivedVolumes} = content;
const pageTitle = `${archive.title} | Saltprint`;
const pageDescription = archive.seoDescription;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalUrl = new URL(`${base}/archive/`, Astro.site ?? Astro.url);
const homeUrl = `${base}/`;
const socialImage = new URL(`${base}/saltprint0logo.png`, Astro.site ?? Astro.url);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl.toString(),
  hasPart: archivedVolumes.map((volume) => ({
    '@type': 'CreativeWork',
    name: `Volume ${volume.volumeNumber}: ${volume.title}`,
    url: `${canonicalUrl.toString()}#${volume.slug}`,
    ...(volume.publicationDate ? {datePublished: volume.publicationDate} : {}),
    image: volume.imageUrl.startsWith('http') ? volume.imageUrl : undefined,
  })),
};
---

<!doctype html>
<html lang="en" class="bg-map-base">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={`${base}/saltprint0logo.png`} />
    <link rel="apple-touch-icon" href={`${base}/saltprint0logo.png`} />
    <link
      rel="preload"
      href={`${base}/fonts/special-elite-latin-400-normal.woff2`}
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href={`${base}/images/hero-map-mobile.webp`}
      as="image"
      type="image/webp"
      fetchpriority="high"
      media="(max-width: 63.999rem)"
    />
    <link
      rel="preload"
      href={`${base}/images/hero-map.webp`}
      as="image"
      type="image/webp"
      fetchpriority="high"
      media="(min-width: 64rem)"
    />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Saltprint" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content="Saltprint logo" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImage} />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
    <title>{pageTitle}</title>
  </head>
  <body class="font-body text-ink">
    <header
      class="newsletter-map overflow-hidden text-ink"
      data-newsletter-parallax
    >
      <div
        class="newsletter-map-layer"
        data-newsletter-map-layer
        aria-hidden="true"
      ></div>

      <div
        class="content-shell section-title-container relative z-10 py-16 sm:py-20 lg:py-28"
      >
        <a
          class="inline-block font-heading text-lg uppercase underline decoration-1 underline-offset-[0.3em] transition-opacity hover:opacity-70 focus-visible:rounded-sm focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-ink motion-reduce:transition-none sm:text-xl"
          href={homeUrl}
        >
          ← Back to Saltprint
        </a>

        <h1
          class="section-title-tile archive-title-tile mx-auto mt-12 -rotate-1 overflow-hidden shadow-xl"
          data-stamp-title
        >
          <img
            class="section-title-art title-palette-blue"
            src={`${base}/images/section_names_img/archive.webp`}
            alt={archive.title}
            width="1940"
            height="558"
            decoding="async"
          />
        </h1>

        <p
          class="mx-auto mt-10 max-w-3xl text-center font-heading text-3xl leading-tight tracking-[0.04em] text-balance sm:text-4xl lg:mt-12 lg:text-5xl"
        >
          {archive.intro}
        </p>
      </div>
    </header>

    <main>
      {
        archivedVolumes.length > 0 ? (
          archivedVolumes.map((volume) => (
            <VolumeSection volume={volume} sectionId={volume.slug} />
          ))
        ) : (
          <section class="dark-paper-texture text-paper">
            <div class="content-shell py-20 text-center sm:py-28">
              <h2 class="text-3xl uppercase sm:text-4xl">The archive starts here</h2>
              <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed sm:text-lg">
                The first completed SALTPRINT volume will appear here when the next open call begins.
              </p>
            </div>
          </section>
        )
      }
    </main>

    <FooterSection />
    <script src="../scripts/motion/sectionTitles.ts"></script>
    <script src="../scripts/motion/newsletterParallax.ts"></script>
  </body>
</html>
