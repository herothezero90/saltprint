---
import OpenCallContent from './OpenCallContent.astro';
import type { OpenCallData } from './openCall';

interface Props extends OpenCallData {
  announcementHref?: string;
}

const openCall = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div
  class="relative w-full max-w-xl justify-self-center min-[1800px]:max-w-[42rem]"
>
  <div class="paper-card w-full font-heading text-paper-ink">
    <article
      class="hero-paper-surface paper-final paper-surface relative overflow-hidden shadow-2xl"
    >
      <img
        class="pointer-events-none absolute inset-0 h-full w-full object-cover"
        src={`${base}/images/hero-paper.webp`}
        srcset={`${base}/images/hero-paper-800.webp 800w, ${base}/images/hero-paper.webp 1400w`}
        sizes="(min-width: 36rem) 36rem, calc(100vw - 2rem)"
        alt=""
        width="1400"
        height="1076"
        fetchpriority="high"
        aria-hidden="true"
      />
      <OpenCallContent {...openCall} />
    </article>
  </div>
</div>
