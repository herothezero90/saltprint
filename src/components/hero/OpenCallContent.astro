---
import type { OpenCallData } from './openCall';

interface Props extends OpenCallData {
  decorative?: boolean;
  announcementHref?: string;
}

const {
  eyebrow,
  volumeLabel,
  title,
  announcement,
  decorative = false,
  announcementHref,
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div class="open-call-content relative flex h-full flex-col justify-center text-center">
  <div class="open-call-copy flex flex-col items-center" data-open-call-copy>
    <div class="open-call-meta flex w-full items-center justify-center whitespace-nowrap">
      <p>{eyebrow} - {volumeLabel}</p>
      <img
        class="open-call-logo h-auto shrink-0"
        src={`${base}/images/open-call-logo-128.webp`}
        srcset={`${base}/images/open-call-logo-128.webp 128w, ${base}/images/open-call-logo.webp 160w`}
        sizes="4rem"
        alt=""
        width="160"
        height="153"
        decoding="async"
        aria-hidden="true"
      />
    </div>
    {
      decorative ? (
        <div class="open-call-title whitespace-nowrap leading-none">
          {title}
        </div>
      ) : (
        <h1 class="open-call-title whitespace-nowrap leading-none">
          {title}
        </h1>
      )
    }
    {
      announcement && (
        announcementHref ? (
          <a
            class="open-call-announcement whitespace-nowrap leading-none text-neutral-900 underline decoration-1 underline-offset-[0.25em] focus-visible:rounded-sm focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-paper-ink"
            href={announcementHref}
          >
            {announcement}
          </a>
        ) : (
          <p class="open-call-announcement whitespace-nowrap leading-none text-neutral-900">
            {announcement}
          </p>
        )
      )
    }
  </div>
</div>

<style>
  .open-call-content {
    padding-block: clamp(3rem, 14cqw, 5rem);
    padding-inline: clamp(2rem, 10cqw, 4rem);
  }

  .open-call-copy {
    gap: clamp(1.25rem, 5cqw, 2rem);
  }

  .open-call-meta {
    gap: clamp(0.5rem, 2cqw, 0.75rem);
    font-size: clamp(1rem, 5.2cqw, 1.875rem);
    line-height: 1;
  }

  .open-call-logo {
    transform: translateY(-0.16em);
    width: clamp(2.5rem, 10cqw, 3.5rem);
  }

  .open-call-title,
  .open-call-announcement {
    font-size: clamp(1.125rem, 6.5cqw, 2.5rem);
  }

  @media (min-width: 1800px) {
    .open-call-content {
      padding-block: clamp(4rem, 14cqw, 6rem);
      padding-inline: clamp(3rem, 10cqw, 5rem);
    }

    .open-call-copy {
      gap: clamp(1.75rem, 5cqw, 2.5rem);
    }

    .open-call-meta {
      font-size: clamp(1.5rem, 5.2cqw, 2.125rem);
    }

    .open-call-logo {
      width: clamp(3rem, 10cqw, 4rem);
    }

    .open-call-title,
    .open-call-announcement {
      font-size: clamp(2rem, 6.5cqw, 3rem);
    }
  }
</style>
