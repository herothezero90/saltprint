---
import RichText from '../content/RichText.astro';
import {defaultSiteContent} from '../../content/defaultContent';
import type {VolumeContent} from '../../content/types';

interface Props {
  volume?: VolumeContent;
  sectionId?: string;
  showArchiveLink?: boolean;
}

const {
  volume = defaultSiteContent.currentVolume,
  sectionId = 'volume-one',
  showArchiveLink = false,
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const titleId = `${sectionId}-title`;
const isSanityImage = volume.imageUrl.startsWith('https://cdn.sanity.io/');
const imageSrc = isSanityImage
  ? `${volume.imageUrl}?auto=format&w=1280&fit=max&q=85`
  : `${base}${volume.imageUrl}`;
const imageSrcset = isSanityImage
  ? `${volume.imageUrl}?auto=format&w=640&fit=max&q=80 640w, ${volume.imageUrl}?auto=format&w=960&fit=max&q=82 960w, ${volume.imageUrl}?auto=format&w=1280&fit=max&q=85 1280w`
  : undefined;
---

<section
  id={sectionId}
  class="dark-paper-texture text-paper"
  aria-labelledby={titleId}
>
  <div
    class="content-shell grid gap-12 py-16 lg:grid-cols-5 lg:items-center lg:gap-16 lg:py-0"
  >
    <div
      class="font-heading text-lg leading-relaxed sm:text-xl lg:col-span-3 lg:py-12 lg:text-2xl"
    >
      <h2
        id={titleId}
        class="text-3xl leading-tight uppercase sm:text-4xl"
      >
        <span class="block">Volume {volume.volumeNumber}:</span>
        <span class="mt-2 block italic normal-case">{volume.title}</span>
      </h2>

      <p class="mt-10">{volume.prompt}</p>

      <RichText
        class="mt-6 font-body text-base leading-relaxed sm:text-lg lg:text-xl"
        value={volume.body}
      />

      {
        showArchiveLink && (
          <a
            class="mt-10 inline-block font-heading text-xl uppercase underline decoration-1 underline-offset-[0.3em] transition-opacity hover:opacity-75 focus-visible:rounded-sm focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-paper motion-reduce:transition-none sm:text-2xl"
            href={`${base}/archive`}
          >
            View Volume Archive →
          </a>
        )
      }
    </div>

    <figure class="w-full lg:col-span-2 lg:justify-self-center">
      <img
        class="h-auto w-full"
        src={imageSrc}
        srcset={imageSrcset}
        sizes="(min-width: 64rem) 32rem, calc(100vw - 2rem)"
        alt={volume.imageAlt}
        width={volume.imageWidth}
        height={volume.imageHeight}
        loading="lazy"
        decoding="async"
      />
      <figcaption class="mt-4 text-sm font-bold sm:text-base">
        Credit: {volume.imageCredit}
      </figcaption>
    </figure>
  </div>
</section>
