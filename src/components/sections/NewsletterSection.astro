---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section
  id="newsletter"
  class="newsletter-map overflow-hidden text-ink"
  aria-labelledby="newsletter-title"
  data-newsletter-parallax
>
  <div
    class="newsletter-map-layer"
    data-newsletter-map-layer
    aria-hidden="true"
  ></div>

  <div
    class="content-shell section-title-container relative z-10 py-16 sm:py-20 lg:py-28"
  >
    <h2
      id="newsletter-title"
      class="section-title-tile section-title-tile-newsletter mx-auto rotate-1 shadow-2xl"
      data-stamp-title
    >
      <img
        class="section-title-art title-palette-blue"
        src={`${base}/images/section_names_img/stay-in-the-archive.webp`}
        alt="Stay in the Archive"
        width="1600"
        height="187"
        loading="lazy"
        decoding="async"
      />
    </h2>

    <div
      class="mt-12 grid gap-10 sm:mt-14 lg:grid-cols-5 lg:items-end lg:gap-16"
    >
      <div class="max-w-xl lg:col-span-3">
        <p
          class="font-heading text-3xl leading-tight text-balance uppercase sm:text-4xl lg:text-5xl"
        >
          Get notified when a new open call begins.
        </p>
        <p class="mt-5 max-w-prose text-base leading-relaxed text-ink/80 sm:text-lg">
          Occasional notes about open calls, new volumes, and the growing
          SALTPRINT archive.
        </p>
      </div>

      <div
        class="newsletter-paper-surface paper-surface -rotate-1 p-5 text-ink shadow-xl sm:p-6 lg:col-span-2"
        data-stamp-title
        data-newsletter-email-card
      >
        <label
          class="block font-heading text-xl uppercase sm:text-2xl"
          for="newsletter-email"
        >
          Email address
        </label>
        <input
          id="newsletter-email"
          class="mt-3 block w-full border-0 border-b-2 border-ink bg-transparent px-0 py-3 text-base text-ink placeholder:text-ink/50 focus:border-link focus-visible:rounded-sm focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-link sm:text-lg"
          type="email"
          inputmode="email"
          autocomplete="email"
          placeholder="Enter your email"
          aria-describedby="newsletter-status"
        />
        <p
          id="newsletter-status"
          class="mt-4 text-xs font-bold tracking-wide uppercase sm:text-sm"
        >
          Sign-up is coming soon.
        </p>
      </div>
    </div>
  </div>
</section>

<script src="../../scripts/motion/newsletterParallax.ts"></script>
