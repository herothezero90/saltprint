---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section
  id="newsletter"
  class="newsletter-map overflow-hidden text-ink"
  aria-labelledby="newsletter-title"
  data-newsletter-parallax
>
  <div
    class="newsletter-map-layer"
    data-newsletter-map-layer
    aria-hidden="true"
  ></div>

  <div
    class="content-shell section-title-container relative z-10 py-16 sm:py-20 lg:py-28"
  >
    <h2
      id="newsletter-title"
      class="section-title-tile section-title-tile-newsletter mx-auto rotate-1 shadow-2xl"
      data-stamp-title
    >
      <span class="sr-only">Stay in the Archive</span>
      <img
        class="section-title-art title-palette-blue"
        src={`${base}/images/section_names_img/stay-in-the-archive-cropped.webp`}
        srcset={`${base}/images/section_names_img/stay-in-the-archive-cropped-800.webp 800w, ${base}/images/section_names_img/stay-in-the-archive-cropped.webp 1340w`}
        sizes="(min-width: 80rem) 50rem, (min-width: 40rem) 77vw, 100vw"
        alt=""
        width="1340"
        height="176"
        loading="lazy"
        decoding="async"
        aria-hidden="true"
      />
    </h2>

    <div class="mt-12 flex flex-col items-center sm:mt-14">
      <div
        class="newsletter-paper-surface paper-surface w-full max-w-3xl overflow-hidden p-5 text-paper shadow-xl sm:p-6"
        data-stamp-title
        data-newsletter-email-card
      >
        <iframe
          class="border-0"
          data-tally-src="https://tally.so/embed/2EyLZg?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
          src="https://tally.so/embed/2EyLZg?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
          loading="lazy"
          width="100%"
          height="177"
          title="Stay in the Archive"
        ></iframe>
      </div>
      <p class="mt-5 text-center font-heading text-base uppercase text-black sm:text-lg">
        No spam. Unsubscribe at any time.
      </p>
    </div>
  </div>
</section>

<script src="../../scripts/motion/newsletterParallax.ts"></script>
<script is:inline>
  var d = document;
  var w = 'https://tally.so/widgets/embed.js';
  var v = function () {
    if (typeof Tally !== 'undefined') {
      Tally.loadEmbeds();
    } else {
      d.querySelectorAll('iframe[data-tally-src]:not([src])').forEach(function (e) {
        e.src = e.dataset.tallySrc;
      });
    }
  };

  if (typeof Tally !== 'undefined') {
    v();
  } else if (d.querySelector('script[src="' + w + '"]') === null) {
    var s = d.createElement('script');
    s.src = w;
    s.onload = v;
    s.onerror = v;
    d.body.appendChild(s);
  }
</script>
