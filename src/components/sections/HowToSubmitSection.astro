---
import RichText from '../content/RichText.astro';
import {defaultSiteContent} from '../../content/defaultContent';
import type {HowToSubmitContent} from '../../content/types';

interface Props {
  content?: HowToSubmitContent;
}

const {content = defaultSiteContent.howToSubmit} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const formUrl = content.statusCard.formUrl?.trim();
const StatusCard = formUrl ? 'a' : 'div';
---

<section
  id="how-to-submit"
  class="dark-paper-texture text-paper"
  aria-labelledby="how-to-submit-title"
>
  <div
    class="content-shell section-title-container py-16 sm:py-20 lg:py-28"
  >
    <h2
      id="how-to-submit-title"
      class="paper-title-surface paper-title-surface-solid section-title-tile section-title-tile-how-to-submit mx-auto rotate-1 shadow-xl"
      data-stamp-title
    >
      <span class="sr-only">How to Submit</span>
      <img
        class="paper-title-art section-title-art"
        src={`${base}/images/section_names_img/how-to-submit-cropped.webp`}
        srcset={`${base}/images/section_names_img/how-to-submit-cropped-537.webp 537w, ${base}/images/section_names_img/how-to-submit-cropped.webp 1074w`}
        sizes="(min-width: 80rem) 42.4rem, (min-width: 40rem) 59vw, 76vw"
        alt=""
        width="1074"
        height="185"
        loading="lazy"
        aria-hidden="true"
      />
    </h2>

    <ol
      class="mt-12 grid gap-6 text-paper md:grid-cols-2 xl:grid-cols-[repeat(3,minmax(0,22rem))] xl:justify-between"
    >
      {
        content.steps.map((step, index) => (
          <li
            class:list={[
              'w-full max-w-88 justify-self-center py-6 sm:py-8',
              index === content.steps.length - 1 && content.steps.length % 2 === 1
                ? 'md:col-span-2 xl:col-span-1'
                : '',
            ]}
          >
            <h3 class="text-2xl sm:text-3xl xl:min-h-18">{step.title}</h3>
            <RichText
              class="mt-4 text-base leading-relaxed sm:text-lg"
              value={step.body}
            />
            {step.codeExample && (
              <code class="mt-3 block break-all text-xs font-bold sm:text-sm">
                {step.codeExample}
              </code>
            )}
          </li>
        ))
      }
    </ol>

    {
      content.statusCard.visible && (
        <StatusCard
          class:list={[
            'about-paper-texture mt-10 block px-6 py-5 text-center text-copy-ink sm:px-8 sm:py-6',
            formUrl
              ? 'cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-paper'
              : '',
          ]}
          href={formUrl || undefined}
          target={formUrl ? '_blank' : undefined}
          rel={formUrl ? 'noopener noreferrer' : undefined}
        >
          <p class="flex items-center justify-center gap-2 font-heading text-2xl uppercase sm:text-3xl">
            {content.statusCard.title}
            {formUrl && (
              <svg
                class="relative bottom-[0.08em] h-[0.85em] w-[0.85em]"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M7 17 17 7" />
                <path d="M7 7h10v10" />
              </svg>
            )}
          </p>
          <p class="mt-2 text-sm sm:text-base">{content.statusCard.body}</p>
        </StatusCard>
      )
    }

    <section
      class="mt-10 pt-8"
      aria-labelledby="submission-privacy-title"
    >
      <h3 id="submission-privacy-title" class="text-xl sm:text-2xl">
        {content.privacyHeading}
      </h3>
      <RichText
        class="mt-4 w-full text-sm leading-relaxed text-paper/80 sm:text-base"
        value={content.privacyBody}
      />
    </section>
  </div>
</section>
