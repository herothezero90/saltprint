---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section
  id="how-to-submit"
  class="dark-paper-texture text-paper"
  aria-labelledby="how-to-submit-title"
>
  <div
    class="content-shell section-title-container py-16 sm:py-20 lg:py-28"
  >
    <h2
      id="how-to-submit-title"
      class="paper-title-surface paper-title-surface-solid section-title-tile section-title-tile-how-to-submit mx-auto rotate-1 shadow-xl"
      data-stamp-title
    >
      <img
        class="paper-title-art section-title-art"
        src={`${base}/images/section_names_img/how-to-submit-cropped.webp`}
        alt="How to Submit"
        width="1074"
        height="185"
        loading="lazy"
      />
    </h2>

    <ol
      class="mt-12 grid gap-6 text-paper md:grid-cols-2 xl:grid-cols-[repeat(3,minmax(0,22rem))] xl:justify-between"
    >
      <li class="w-full max-w-[22rem] justify-self-center py-6 sm:py-8">
        <h3 class="text-2xl sm:text-3xl xl:min-h-[4.5rem]">Complete the form</h3>
        <p class="mt-4 text-base leading-relaxed sm:text-lg">
          Provide your name, email, photograph title, location, and a short note
          about why the image mattered to you.
        </p>
      </li>

      <li class="w-full max-w-[22rem] justify-self-center py-6 sm:py-8">
        <h3 class="text-2xl sm:text-3xl xl:min-h-[4.5rem]">
          Upload your photograph
        </h3>
        <p class="mt-4 text-base leading-relaxed sm:text-lg">
          Upload one image as a JPG or PNG file, maximum 10 MB.
        </p>
      </li>

      <li
        class="w-full max-w-[22rem] justify-self-center py-6 sm:py-8 md:col-span-2 xl:col-span-1"
      >
        <h3 class="text-2xl sm:text-3xl xl:min-h-[4.5rem]">
          Name your file clearly
        </h3>
        <p class="mt-4 text-base leading-relaxed sm:text-lg">
          Use this format:
        </p>
        <code
          class="mt-3 block break-all text-xs font-bold sm:text-sm"
        >FirstName_LastName_PhotoTitle.jpg</code>
      </li>
    </ol>

    <div
      class="about-paper-texture mt-10 px-6 py-5 text-center text-copy-ink sm:px-8 sm:py-6"
    >
      <p class="font-heading text-2xl uppercase sm:text-3xl">
        Submissions opening soon
      </p>
      <p class="mt-2 text-sm sm:text-base">
        The submission form will be available here when the open call begins.
      </p>
    </div>

    <section
      class="mt-10 pt-8"
      aria-labelledby="submission-privacy-title"
    >
      <h3 id="submission-privacy-title" class="text-xl sm:text-2xl">
        Your privacy
      </h3>
      <p
        class="mt-4 w-full text-sm leading-relaxed text-paper/80 sm:text-base"
      >
        Your name, email address, submission text, and photograph will be used only to review your submission and contact you about the next volume. Unselected submissions will be deleted after the selection process. Mailing-list subscriptions are handled separately.
      </p>
    </section>
  </div>
</section>
