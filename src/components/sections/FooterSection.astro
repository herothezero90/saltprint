---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer
  class="dark-paper-texture overflow-hidden text-paper"
  aria-label="Site footer"
>
  <div
    class="content-shell flex flex-col pt-14 pb-7 sm:pt-20 sm:pb-9 lg:pt-24 lg:pb-12"
  >
    <div
      class="paper-title-surface paper-title-surface-solid surface-wear-overlay mx-auto w-full max-w-3xl rotate-1 shadow-2xl md:max-w-xl lg:max-w-3xl"
      data-stamp-title
    >
      <img
        class="paper-title-art h-auto w-full"
        src={`${base}/images/saltprint-footer-reversed.webp`}
        srcset={`${base}/images/saltprint-footer-reversed-800.webp 800w, ${base}/images/saltprint-footer-reversed-1600.webp 1600w, ${base}/images/saltprint-footer-reversed.webp 2124w`}
        sizes="(min-width: 64rem) 48rem, (min-width: 48rem) 36rem, calc(100vw - 2rem)"
        alt="Saltprint"
        width="2124"
        height="353"
        loading="lazy"
        decoding="async"
      />
      <span class="surface-wear-layer" aria-hidden="true"></span>
    </div>

    <nav
      class="mt-12 sm:mt-16 lg:mt-20"
      aria-label="Contact and social links"
    >
      <ul
        class="flex flex-nowrap items-center justify-center gap-x-5 font-heading text-xl uppercase sm:gap-x-8 sm:text-2xl lg:gap-x-12 lg:text-3xl"
      >
        <li>
          <a
            class="inline-block underline decoration-transparent decoration-2 underline-offset-[0.3em] transition-colors duration-150 hover:decoration-current focus-visible:rounded-sm focus-visible:outline-2 focus-visible:outline-offset-8 focus-visible:outline-paper motion-reduce:transition-none"
            href="mailto:saltprintzine@gmail.com"
            aria-label="Email Saltprint at saltprintzine@gmail.com"
          >Email</a>
        </li>
        <li>
          <a
            class="inline-block underline decoration-transparent decoration-2 underline-offset-[0.3em] transition-colors duration-150 hover:decoration-current focus-visible:rounded-sm focus-visible:outline-2 focus-visible:outline-offset-8 focus-visible:outline-paper motion-reduce:transition-none"
            href="https://www.instagram.com/saltprint_zine/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Saltprint on Instagram"
          >Instagram</a>
        </li>
      </ul>
    </nav>

    <p
      class="mt-10 text-center text-xs leading-relaxed text-balance sm:mt-12 sm:text-sm lg:mt-14 lg:text-lg"
    >
      SALTPRINT is an independent, self-funded photography zine and archive
      founded in Zagreb, Croatia, 2026.
    </p>
  </div>
</footer>
