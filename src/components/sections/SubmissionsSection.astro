---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section
  id="submissions"
  class="about-paper-texture text-copy-ink"
  aria-labelledby="submissions-title"
>
  <div
    class="content-shell section-title-container py-16 sm:py-20 lg:py-28"
  >
    <h2
      id="submissions-title"
      class="section-title-tile section-title-tile-submissions mx-auto -rotate-1 shadow-xl"
      data-stamp-title
    >
      <img
        class="section-title-art title-palette-blue"
        src={`${base}/images/section_names_img/submision-rules-and-selection.png`}
        alt="Submission, Rules and Selection"
        width="2138"
        height="250"
        loading="lazy"
      />
    </h2>

    <section class="mt-12" aria-labelledby="important-dates-title">
      <h3 id="important-dates-title" class="text-2xl sm:text-3xl">
        Important Dates
      </h3>

      <dl
        class="mt-6 grid gap-8 py-8 sm:grid-cols-2 xl:grid-cols-4"
      >
        <div>
          <dt class="text-sm font-bold tracking-wide uppercase">
            Submissions open
          </dt>
          <dd class="mt-2 font-heading text-2xl uppercase">Soon</dd>
        </div>

        <div>
          <dt class="text-sm font-bold tracking-wide uppercase">
            Submission deadline
          </dt>
          <dd class="mt-2 font-heading text-2xl uppercase">TBD</dd>
        </div>

        <div>
          <dt class="text-sm font-bold tracking-wide uppercase">
            Selected photographers contacted
          </dt>
          <dd class="mt-2 font-heading text-2xl">September 2026</dd>
        </div>

        <div>
          <dt class="text-sm font-bold tracking-wide uppercase">
            Volume 01 publication
          </dt>
          <dd class="mt-2 font-heading text-2xl">October 2026</dd>
        </div>
      </dl>
    </section>

    <div class="mt-14 grid gap-12 lg:grid-cols-2 lg:gap-x-16 lg:gap-y-14">
      <div class="grid gap-12 lg:gap-14">
        <section
          class="bg-transparent"
          aria-labelledby="who-can-submit-title"
        >
          <h3 id="who-can-submit-title" class="text-2xl sm:text-3xl">
            Who Can Submit
          </h3>
          <p class="mt-5 max-w-prose text-base leading-relaxed sm:text-lg">
            Anyone over the age of 18 can submit. You do not need to be a
            professional photographer - beginners, students, self-taught, and
            previously unpublished photographers are all welcome. You can submit
            from any country, but the photograph itself must have been taken in
            Europe.
          </p>
        </section>

        <section
          class="bg-transparent"
          aria-labelledby="what-to-submit-title"
        >
          <h3 id="what-to-submit-title" class="text-2xl sm:text-3xl">
            What You Can Submit
          </h3>
          <p class="mt-5 max-w-prose text-base leading-relaxed sm:text-lg">
            One photograph responding to the theme <em>From Where You Stand</em>,
            taken somewhere in Europe. Digital, film, black and white, colour,
            street, documentary, landscape, portrait - any approach is welcome,
            shot on a camera or a phone.{' '}
            <strong>AI-generated images are not accepted.</strong>
          </p>
        </section>
      </div>

      <section
        class="bg-transparent"
        aria-labelledby="submission-rules-title"
      >
        <h3 id="submission-rules-title" class="text-2xl sm:text-3xl">
          Submission Rules
        </h3>

        <ul
          class="mt-5 list-disc space-y-5 pl-5 text-base leading-relaxed sm:text-lg"
        >
          <li class="pl-2">
            Submit only your own original work - you must own the rights to the
            image.
          </li>
          <li class="pl-2">
            Only one photograph per person for this volume.
          </li>
          <li class="pl-2">
            Basic editing and post-processing are allowed, including cropping,
            colour correction, exposure adjustments, contrast, and dust removal.
            Do not add watermarks, borders, logos, or text to the image.
          </li>
          <li class="pl-2">
            By submitting, you confirm you're the creator and give SALTPRINT
            permission to publish the selected photograph in print, on the
            website, and on social media, with credit.{' '}
            <strong>You keep full copyright.</strong>
          </li>
        </ul>
      </section>

      <section
        class="bg-transparent lg:col-span-2"
        aria-labelledby="selection-title"
      >
        <h3 id="selection-title" class="text-2xl sm:text-3xl">
          How Selection Works
        </h3>
        <div
          class="mt-5 space-y-4 text-base leading-relaxed sm:text-lg"
        >
          <p>
            Photographs are reviewed based on connection to the theme, visual
            strength, atmosphere, and originality - not technical perfection.
            We're looking for images that stay with us. Selected photographers
            will be contacted by email before publication.
          </p>
          <p>
            Three featured photographers from each volume will also be invited to
            take part in a short written interview.
          </p>
        </div>
      </section>
    </div>
  </div>
</section>
