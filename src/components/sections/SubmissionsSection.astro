---
import RichText from '../content/RichText.astro';
import {defaultSiteContent} from '../../content/defaultContent';
import type {SubmissionsContent} from '../../content/types';

interface Props {
  content?: SubmissionsContent;
}

const {content = defaultSiteContent.submissions} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section
  id="submissions"
  class="about-paper-texture text-copy-ink"
  aria-labelledby="submissions-title"
>
  <div
    class="content-shell section-title-container py-16 sm:py-20 lg:py-28"
  >
    <h2
      id="submissions-title"
      class="section-title-tile section-title-tile-submissions mx-auto -rotate-1 shadow-xl"
      data-stamp-title
    >
      <img
        class="section-title-art title-palette-blue"
        src={`${base}/images/section_names_img/submision-rules-and-selection-cropped.webp`}
        alt="Submission, Rules and Selection"
        width="2012"
        height="204"
        loading="lazy"
      />
    </h2>

    <div class="mt-12">
      <dl
        class="grid gap-8 py-8 sm:grid-cols-2 xl:grid-cols-4"
      >
        {
          content.importantDates.map(({label, value}) => (
            <div>
              <dt class="text-sm font-bold tracking-wide uppercase">{label}</dt>
              <dd class="mt-2 font-heading text-2xl">{value}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div class="mt-14 grid gap-12 lg:grid-cols-2 lg:gap-x-16 lg:gap-y-14">
      <div class="grid gap-12 lg:gap-14">
        <section
          class="bg-transparent"
          aria-labelledby="who-can-submit-title"
        >
          <h3 id="who-can-submit-title" class="text-2xl sm:text-3xl">
            {content.whoCanSubmit.heading}
          </h3>
          <RichText
            class="mt-5 max-w-prose text-base leading-relaxed sm:text-lg"
            value={content.whoCanSubmit.body}
          />
        </section>

        <section
          class="bg-transparent"
          aria-labelledby="what-to-submit-title"
        >
          <h3 id="what-to-submit-title" class="text-2xl sm:text-3xl">
            {content.whatToSubmit.heading}
          </h3>
          <RichText
            class="mt-5 max-w-prose text-base leading-relaxed sm:text-lg"
            value={content.whatToSubmit.body}
          />
        </section>
      </div>

      <section
        class="bg-transparent"
        aria-labelledby="submission-rules-title"
      >
        <h3 id="submission-rules-title" class="text-2xl sm:text-3xl">
          {content.rules.heading}
        </h3>

        <RichText
          class="mt-5 text-base leading-relaxed sm:text-lg"
          value={content.rules.body}
        />
      </section>

      <section
        class="bg-transparent lg:col-span-2"
        aria-labelledby="selection-title"
      >
        <h3 id="selection-title" class="text-2xl sm:text-3xl">
          {content.selection.heading}
        </h3>
        <RichText
          class="mt-5 text-base leading-relaxed sm:text-lg"
          value={content.selection.body}
        />
      </section>
    </div>
  </div>
</section>
